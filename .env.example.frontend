# Frontend Environment Variables
# Copy this file to .env.local and update with your values

# API Configuration
VITE_API_URL=http://localhost:8000/api
VITE_API_TIMEOUT=10000

# Application Environment
# Options: development, production, staging
VITE_APP_ENV=development
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false
VITE_SOURCEMAP=true
VITE_DROP_CONSOLE=false

# Google OAuth 2.0 Configuration (Required for social sign-in)
# Setup instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project (or select existing)
# 3. Enable "Google+ API" or "Google Identity"
# 4. Go to "Credentials" and create "OAuth 2.0 Client ID"
# 5. Select "Web application" and add these authorized redirect URIs:
#    - http://localhost:5173
#    - http://localhost:5174
#    - http://localhost:3000 (if using different dev port)
# 6. Copy the Client ID value and paste it below
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here
