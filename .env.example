# Environment Variables Template
# Copy this file to .env.local and fill in the required values

# Application Environment
VITE_APP_ENV=development
VITE_APP_NAME=ALERA Healthcare
VITE_APP_VERSION=1.0.0

# API Configuration
# In local development you can point the frontend to a separate backend origin.
# `VITE_API_URL` is the primary key; `VITE_API_BASE_URL` is still supported for compatibility.
# VITE_API_URL=http://localhost:8000/api
# VITE_API_BASE_URL=http://localhost:8000/api
# VITE_API_TIMEOUT=10000
# VITE_SOURCEMAP=true
# VITE_DROP_CONSOLE=false

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_REPORTING=false

# Sentry (Optional - for error tracking)
# VITE_SENTRY_DSN=

# Analytics (Optional - if using Google Analytics)
# VITE_GA_MEASUREMENT_ID=
