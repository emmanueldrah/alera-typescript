# Environment Variables Template
# Copy this file to .env.local and fill in the required values

# Application Environment
VITE_APP_ENV=production
VITE_APP_NAME=ALERA Healthcare
VITE_APP_VERSION=1.0.0

# API Configuration (if needed in future)
# VITE_API_BASE_URL=https://api.alera.health
# VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Sentry (Optional - for error tracking)
# VITE_SENTRY_DSN=

# Analytics (Optional - if using Google Analytics)
# VITE_GA_MEASUREMENT_ID=
