# Backend Environment Configuration

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/alera_db
DATABASE_ECHO=False

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","https://alera-typescript.vercel.app"]

# Email delivery
# Choose one real provider in production:
# - RESEND_API_KEY for Resend
# - SENDGRID_API_KEY for SendGrid
# - SMTP_HOST/SMTP_USERNAME/SMTP_PASSWORD for SMTP
EMAIL_PROVIDER=auto
EMAIL_FROM_NAME=ALERA Healthcare
EMAIL_FROM_EMAIL=noreply@alera.health
EMAIL_TIMEOUT_SECONDS=10

# Resend
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@alera.health

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@alera.health

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=True
SMTP_USE_SSL=False

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Environment
ENVIRONMENT=development
DEBUG=True

# WebRTC/Telemedicine
AGORA_APP_ID=your-agora-app-id
AGORA_APP_CERTIFICATE=your-agora-cert

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# HIPAA Compliance
ENCRYPTION_KEY=your-fernet-encryption-key
AUDIT_LOG_RETENTION_DAYS=2555
