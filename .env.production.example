# =============================================================================
# ALERA Production Environment Variables
# Copy this file to .env for production deployment
# =============================================================================

# ================================
# ENVIRONMENT CONFIGURATION
# ================================
ENVIRONMENT=production
VITE_APP_ENV=production
DEBUG=false

# ================================
# DATABASE CONFIGURATION (Vercel)
# ================================
# For Vercel deployment, use a managed PostgreSQL, MySQL, or Neon database
# Example for Neon PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:5432/alera?sslmode=require
DATABASE_URL=sqlite:////tmp/alera.db

# ================================
# SECURITY - JWT & TOKENS
# ================================
# CRITICAL: Generate a strong secret key for production
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-production-secret-key-change-this-immediately

# ================================
# REDIS (Optional but recommended)
# ================================
# For production, use Redis Cloud or similar managed service
REDIS_URL=redis://user:password@host:6379/0

# ================================
# EMAIL SERVICE
# ================================
# Choose one real provider:
# - Resend: https://resend.com
# - SendGrid: https://app.sendgrid.com/settings/api_keys
# - SMTP: your mail host
EMAIL_PROVIDER=auto
EMAIL_FROM_NAME=ALERA Healthcare
EMAIL_FROM_EMAIL=noreply@alera.health
EMAIL_TIMEOUT_SECONDS=10

# Resend
RESEND_API_KEY=your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@alera.health

# SendGrid
SENDGRID_API_KEY=your-sendgrid-api-key-here
SENDGRID_FROM_EMAIL=noreply@alera.health

# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# ================================
# SMS SERVICE (Twilio) - Optional
# ================================
# Get credentials from: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=your-twilio-account-sid-here
TWILIO_AUTH_TOKEN=your-twilio-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890

# ================================
# VIDEO/VOICE CALLS (Agora) - Optional
# ================================
# Get credentials from: https://console.agora.io/
AGORA_APP_ID=your-agora-app-id-here
AGORA_APP_CERTIFICATE=your-agora-app-certificate-here

# ================================
# FRONTEND API CONFIGURATION
# ================================
# Used by React app to connect to API
VITE_API_URL=/api

# ================================
# FEATURES & ANALYTICS
# ================================
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# Optional: Sentry for error tracking
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Optional: Google Analytics
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ================================
# HIPAA & COMPLIANCE
# ================================
# Encryption key for sensitive data
ENCRYPTION_KEY=your-encryption-key-change-this

# Audit log retention (days)
AUDIT_LOG_RETENTION_DAYS=2555

# ================================
# CORS Configuration
# ================================
# Automatically includes Vercel deployment URLs
# Regex pattern allows all Vercel preview URLs
CORS_ORIGIN_REGEX=https://.*\.vercel\.app
